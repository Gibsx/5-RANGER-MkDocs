# /opt/mkdocs-sync/config.env — chmod 600, root-owned (contains a PAT).
#
# REPO    Owner/repo of the RANGER-AIDE-MEMOIRE content repo. Same repo
#         the bot pulls from — two independent pullers is fine.
# BRANCH  Branch to mirror. Typically "main".
# TOKEN   Fine-grained GitHub PAT with Contents: Read on the content repo.
#         Can be the same token the bot uses, or a dedicated one.
# DOCS_DIR    Where mkdocs serves from. Files here are overwritten on every
#             publish; don't hand-edit. Must be writable by the user the
#             script runs as (root by default).
# MKDOCS_YML  Path to the mkdocs config. Regenerated from manifest.yaml on
#             every publish — don't hand-edit the nav; edit theme/markdown
#             extensions in sync.py's _MKDOCS_CONFIG_BASE instead.
# STATE_FILE  Where the last-published SHA is persisted so idempotent
#             poll ticks (no content change) exit fast.
REPO=Gibsx/RANGER-AIDE-MEMOIRE
BRANCH=main
TOKEN=github_pat_REPLACE_ME
DOCS_DIR=/opt/mkdocs/docs
MKDOCS_YML=/opt/mkdocs/mkdocs.yml
STATE_FILE=/opt/mkdocs-sync/state.json
